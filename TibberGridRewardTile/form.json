{
  "elements": [
    {
      "type": "Label",
      "caption": "Eigenständige Kachel für die Tibber Grid Rewards. Wähle die TibberGridReward-Instanz als Datenquelle. Die Kachel füllt die Tile randlos und ist von der Datenverbindung getrennt."
    },
    {
      "type": "SelectInstance",
      "name": "SourceInstance",
      "caption": "Datenquelle (TibberGridReward-Instanz)",
      "validModules": ["{E92F62F4-88A6-4C6E-9F0D-E76C3B1C9A01}"]
    },
    {
      "type": "ExpansionPanel",
      "caption": "🎨 Statusfarben",
      "items": [
        { "type": "SelectColor", "name": "ColorActive", "caption": "Einsatz aktiv" },
        { "type": "SelectColor", "name": "ColorAvailable", "caption": "Verfügbar" },
        { "type": "SelectColor", "name": "ColorUnavailable", "caption": "Nicht verfügbar" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "🖌️ Flächen & Text",
      "items": [
        { "type": "SelectColor", "name": "ColorBackground", "caption": "Hintergrund" },
        { "type": "SelectColor", "name": "ColorBox", "caption": "Kacheln/Boxen" },
        { "type": "SelectColor", "name": "ColorText", "caption": "Text (Werte)" },
        { "type": "SelectColor", "name": "ColorTextMuted", "caption": "Text (Beschriftungen)" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "🔤 Schrift",
      "items": [
        {
          "type": "Select",
          "name": "FontFamily",
          "caption": "Schriftart",
          "options": [
            { "caption": "System (Standard)", "value": "system" },
            { "caption": "Arial", "value": "arial" },
            { "caption": "Verdana", "value": "verdana" },
            { "caption": "Tahoma", "value": "tahoma" },
            { "caption": "Trebuchet MS", "value": "trebuchet" },
            { "caption": "Georgia (Serif)", "value": "georgia" },
            { "caption": "Courier New (Monospace)", "value": "courier" }
          ]
        },
        {
          "type": "NumberSpinner",
          "name": "FontScale",
          "caption": "Schriftgröße (Faktor)",
          "digits": 2,
          "minimum": 0.5,
          "maximum": 2.5,
          "suffix": "×"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Farben & Schrift auf Standard zurücksetzen",
      "onClick": "TGRTILE_ResetStyle($id);"
    }
  ],
  "status": [
    { "code": 102, "icon": "active", "caption": "Aktiv" },
    { "code": 104, "icon": "inactive", "caption": "Keine Datenquelle gewählt" }
  ]
}
